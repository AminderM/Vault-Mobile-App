{
  "expo": {
    "name": "Integra Vault",
    "slug": "vault-by-integra-ai",
    "scheme": "integravault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#030303"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.integraatech.vault",
      "associatedDomains": [
        "applinks:vault.integratedtech.ca",
        "applinks:vault.staging.integratedtech.ca"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#030303"
      },
      "package": "com.integraatech.vault",
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "minSdkVersion": 21,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "vault.integratedtech.ca",
              "pathPrefix": "/invite"
            },
            {
              "scheme": "https",
              "host": "vault.staging.integratedtech.ca",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to your photos to scan documents.",
          "cameraPermission": "Allow access to your camera to scan documents."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Integra Vault to use your location to track deliveries."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#CC2222"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "32fafbb0-7206-4482-b703-6211eb92365c"
      },
      "backendUrl": "https://api.staging.integratedtech.ca"
    },
    "runtimeVersion": "1.0.0"
  }
}
